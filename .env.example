# Server
NODE_ENV=production
PORT=3000

# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication (required - generate a secure random string)
JWT_SECRET=your_secure_random_string_at_least_32_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS and email links)
FRONTEND_URL=https://your-frontend-domain.com

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_CRON=0 * * * *

# Logging
LOG_LEVEL=info

# Redis (optional - improves queue reliability)
# REDIS_URL=redis://localhost:6379

# External Scraping Provider (optional - for anti-bot bypass)
# Options: none, scrapingbee, scraperapi, zenrows
SCRAPING_PROVIDER=none
SCRAPING_API_KEY=

# Rate Limiting (per user)
MAX_JOBS_PER_USER_PER_HOUR=100
MAX_JOBS_PER_USER_PER_DAY=500

# Email (Resend - https://resend.com)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=PriceHawk <notifications@yourdomain.com>
